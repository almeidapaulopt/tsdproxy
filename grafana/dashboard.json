{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for TSDProxy metrics",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "2.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "state-timeline",
      "name": "State timeline",
      "version": ""
    },
    {
      "type": "panel",
      "id": "heatmap",
      "name": "Heatmap",
      "version": ""
    }
  ],
  "title": "TSDProxy",
  "description": "Grafana dashboard for TSDProxy — per-proxy metrics, health, connections, and TLS certificate expiry",
  "tags": ["tsdproxy", "tailscale", "proxy"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "panels": [
    {
      "title": "Overall System Status",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "title": "Active Proxies",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "tsdproxy_proxies",
          "legendFormat": "proxies",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "title": "Proxies by Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 4, "y": 1 },
      "targets": [
        {
          "expr": "count(tsdproxy_proxy_status{status=\"Running\"} == 1)",
          "legendFormat": "Running",
          "refId": "A"
        },
        {
          "expr": "count(tsdproxy_proxy_status{status=\"Error\"} == 1)",
          "legendFormat": "Error",
          "refId": "B"
        },
        {
          "expr": "count(tsdproxy_proxy_status{status=\"Paused\"} == 1)",
          "legendFormat": "Paused",
          "refId": "C"
        },
        {
          "expr": "count(tsdproxy_proxy_status{status=~\"Stopped|Stopping\"} == 1)",
          "legendFormat": "Stopped",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "title": "Total Requests per Second",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(tsdproxy_proxy_requests_total[5m]))",
          "legendFormat": "Total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "rps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "auto"
          }
        }
      },
      "options": {
        "legend": { "showLegend": true, "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Average Latency (p95)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(tsdproxy_proxy_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "graphMode": "sparkline",
        "colorMode": "background",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "title": "Per-Proxy Health Grid",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "title": "Proxy Health",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "tsdproxy_proxy_up",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "tsdproxy_proxy_status == 1",
          "format": "table",
          "instant": true,
          "refId": "B"
        }
      ],
      "transformations": [
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "proxy": {
                "aggregations": ["aggregate"],
                "aggregateByLastValue": true
              },
              "Value #A": {
                "aggregations": ["lastNotNull"],
                "aggregateByLastValue": false
              }
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          },
          "displayName": "Health",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "-1": { "text": "Unknown", "color": "orange" },
                "0": { "text": "Down", "color": "red" },
                "1": { "text": "Up", "color": "green" }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true
      }
    },
    {
      "title": "TLS Certificate Expiry",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "tsdproxy_cert_expiry_seconds",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": {
            "fields": "Value #A",
            "type": "time"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto" },
          "displayName": "Expires In",
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 604800 },
              { "color": "green", "value": 2592000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true
      }
    },
    {
      "title": "Request & Traffic Analysis",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 }
    },
    {
      "title": "Request Rate by Proxy",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 17 },
      "targets": [
        {
          "expr": "sum(rate(tsdproxy_proxy_requests_total[5m])) by (proxy)",
          "legendFormat": "{{proxy}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "rps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": { "showLegend": true, "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Error Rate by Proxy",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 17 },
      "targets": [
        {
          "expr": "sum(rate(tsdproxy_proxy_requests_total{code=~\"5..\"}[5m])) by (proxy)",
          "legendFormat": "{{proxy}} errors",
          "refId": "A"
        },
        {
          "expr": "sum(rate(tsdproxy_proxy_requests_total{code=~\"4..\"}[5m])) by (proxy)",
          "legendFormat": "{{proxy}} client errors",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "rps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": { "showLegend": true, "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Request Latency Heatmap",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 17 },
      "targets": [
        {
          "expr": "sum(rate(tsdproxy_proxy_request_duration_seconds_bucket[5m])) by (le)",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "options": {
        "calculate": false,
        "yAxis": {
          "axisPlacement": "left",
          "reverse": false,
          "unit": "s",
          "decimals": 3
        },
        "rowsFrame": { "layout": "le" },
        "legend": { "show": true }
      }
    },
    {
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 25 },
      "targets": [
        {
          "expr": "sum(tsdproxy_proxy_connections_active) by (proxy)",
          "legendFormat": "{{proxy}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": { "showLegend": true, "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "UDP Clients per Proxy",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 25 },
      "targets": [
        {
          "expr": "sum(tsdproxy_udp_clients_active) by (proxy)",
          "legendFormat": "{{proxy}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": { "showLegend": true, "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Proxy Status Timeline",
      "type": "state-timeline",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 25 },
      "targets": [
        {
          "expr": "tsdproxy_proxy_status",
          "legendFormat": "{{proxy}} — {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "Running": { "color": "green" },
                "Error": { "color": "red" },
                "Paused": { "color": "orange" },
                "Stopped": { "color": "gray" },
                "Initializing": { "color": "blue" },
                "Starting": { "color": "blue" },
                "Stopping": { "color": "yellow" },
                "AuthFailed": { "color": "red" },
                "DeviceConflict": { "color": "purple" }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "mergeValues": true,
        "rowHeight": 0.5,
        "showValue": "always",
        "alignValue": "center",
        "legend": { "showLegend": true }
      }
    },
    {
      "title": "In-Flight Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "targets": [
        {
          "expr": "sum(tsdproxy_proxy_requests_in_flight) by (proxy)",
          "legendFormat": "{{proxy}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "fillOpacity": 30
          }
        }
      },
      "options": {
        "legend": { "showLegend": true, "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Status Code Distribution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "targets": [
        {
          "expr": "sum(rate(tsdproxy_proxy_requests_total[5m])) by (code)",
          "legendFormat": "HTTP {{code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "rps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": { "showLegend": true, "placement": "right" },
        "stacking": { "mode": "normal", "group": "A" },
        "tooltip": { "mode": "multi" }
      }
    }
  ]
}
